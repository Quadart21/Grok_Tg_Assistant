{
  "use_schedule": true,
  "timezone_offset_hours": null,
  "activity_windows": [
    {"days": [0, 1, 2, 3, 4], "start": "10:00", "end": "14:00"},
    {"days": [0, 1, 2, 3, 4], "start": "18:00", "end": "23:00"},
    {"days": [5, 6], "start": "12:00", "end": "22:00"}
  ],
  "online_probability": 0.55,
  "quiet_break_min_min": 15,
  "quiet_break_max_min": 90,
